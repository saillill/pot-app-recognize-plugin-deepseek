{
  "id": "plugin.com.pot-app.deepseek_recognize",
  "plugin_type": "recognize",
  "icon": "deepseek.svg",
  "display": "DeepSeek OCR",
  "homepage": "https://github.com/saillill/pot-app-recognize-plugin-deepseek",
  "needs": [
    {
      "key": "model",
      "display": "模型",
      "type": "select",
      "options": {
        "deepseek-ai/DeepSeek-OCR": "DeepSeek-OCR (文字识别)",
        "deepseek-ai/deepseek-vl2": "DeepSeek-VL2 (通用视觉)",
        "gpt-4o": "GPT-4o (OpenAI)",
        "Qwen/Qwen3-VL-8B": "Qwen3-VL-8B",
        "Pro/Qwen/Qwen3-VL-8B": "Qwen3-VL-8B (第三方)",
        "Qwen/Qwen3-VL-32B": "Qwen3-VL-32B"
      }
    },
    {
      "key": "requestPath",
      "display": "请求地址",
      "type": "input",
      "hint": "https://api.siliconflow.cn"
    },
    {
      "key": "apiKey",
      "display": "API Key",
      "type": "input"
    },
    {
      "key": "customPrompt",
      "display": "自定义 Prompt",
      "type": "input",
      "hint": "<image>\nFree OCR."
    }
  ],
  "language": {
